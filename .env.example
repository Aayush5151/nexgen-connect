# ============================================
# Site
# ============================================
# In production set this to the https:// canonical origin (no trailing slash).
# e.g. NEXT_PUBLIC_SITE_URL=https://nexgenconnect.in
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Supabase
# Required in every environment.
# Service role key is SECRET — never expose to the browser.
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# MSG91 (SMS OTP)
#
# In dev keep MOCK_OTP=true — the verify step accepts 000000 and no SMS is
# sent. In production set MOCK_OTP=false (or remove the var) AND set the
# three MSG91 values below.
#
# MSG91_TEMPLATE_ID must correspond to an approved template with variable
# {{otp}} length 6, sent via the SENDER ID you've whitelisted with MSG91
# (SENDER_ID defaults to NXGNCN — change to whatever is whitelisted for you).
#
# Boot-time env check (src/lib/env.ts) logs a loud red warning if MOCK_OTP
# is true in a production runtime — do not ignore it.
# ============================================
MOCK_OTP=true
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=NXGNCN

# ============================================
# Resend (transactional email)
# Required for the welcome email after phone OTP. Without it, verify still
# works but the confirmation email silently fails (logged server-side).
# ============================================
RESEND_API_KEY=
RESEND_FROM_ADDRESS="NexGen Connect <hello@nexgenconnect.com>"

# ============================================
# Server-side hashing peppers
#   Generate each with: openssl rand -hex 32
#   Each must be ≥ 32 chars. Rotating behaviour:
#     - PHONE_PEPPER   → invalidates phone_hash, email_hash, ip_hash, ua_hash
#     - OTP_PEPPER     → only affects in-flight OTPs (always safe)
#     - AADHAAR_REF_PEPPER → invalidates digilocker_reference_id uniqueness
#
# NEVER commit real values. Set via Vercel dashboard / `vercel env`.
# ============================================
PHONE_PEPPER=
OTP_PEPPER=
AADHAAR_REF_PEPPER=

# ============================================
# Verification session cookie secret
#   Generate with: openssl rand -hex 32 (≥ 32 chars required).
#   Signs the short-lived HttpOnly cookie that links phone-OTP success to
#   the downstream DigiLocker + admit-letter flow. Rotate to invalidate
#   all in-flight verification sessions.
# ============================================
SESSION_SECRET=

# ============================================
# DigiLocker (Aadhaar identity)
#
# For the v1 launch keep DIGILOCKER_ENABLED=false. The phone-OTP + admit-
# letter flow is sufficient to gate waitlist entry; identity verification
# can light up as a second wave once partner credentials land.
#
# When you're ready: set DIGILOCKER_ENABLED=true, MOCK_DIGILOCKER=false,
# and fill the four values below. Partner onboarding guide:
#   https://partners.digitallocker.gov.in
# ============================================
DIGILOCKER_ENABLED=false
MOCK_DIGILOCKER=true
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_REDIRECT_URI=http://localhost:3000/api/digilocker/callback
DIGILOCKER_BASE_URL=https://api.digitallocker.gov.in

# ============================================
# Plausible analytics (public, loaded in the browser)
# ============================================
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=nexgenconnect.com
