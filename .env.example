# ============================================
# Site
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Supabase
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# MSG91 (SMS OTP) — keep MOCK_OTP=true in dev; OTP code is 000000
# ============================================
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=NXGNCN
MOCK_OTP=true

# ============================================
# Resend (transactional email)
# ============================================
RESEND_API_KEY=
RESEND_FROM_ADDRESS="NexGen Connect <hello@nexgenconnect.com>"

# ============================================
# Server-side hashing peppers — generate each with: openssl rand -hex 32
# Rotating PHONE_PEPPER breaks phone_hash, email_hash, ip_hash, ua_hash.
# Rotating OTP_PEPPER only affects in-flight OTPs (always safe).
# Rotating AADHAAR_REF_PEPPER breaks digilocker_reference_id uniqueness.
# ============================================
PHONE_PEPPER=
OTP_PEPPER=
AADHAAR_REF_PEPPER=

# ============================================
# Verification session cookie — generate with: openssl rand -hex 32
# Signs the short-lived cookie that links phone-OTP → DigiLocker callback.
# Rotate to invalidate all in-flight verification sessions.
# ============================================
SESSION_SECRET=

# ============================================
# DigiLocker (Aadhaar identity)
# Keep MOCK_DIGILOCKER=true in dev — returns fake-but-structurally-valid data.
# Partner onboarding: https://partners.digitallocker.gov.in
# Set DIGILOCKER_ENABLED=true only when production creds land.
# ============================================
DIGILOCKER_ENABLED=false
MOCK_DIGILOCKER=true
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_REDIRECT_URI=http://localhost:3000/api/digilocker/callback
DIGILOCKER_BASE_URL=https://api.digitallocker.gov.in

# ============================================
# Plausible analytics
# ============================================
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=nexgenconnect.com
