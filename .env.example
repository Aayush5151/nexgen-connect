# ============================================
# Site
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Supabase
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# MSG91 (SMS OTP) — keep MOCK_OTP=true in dev; OTP code is 000000
# ============================================
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=NXGNCN
MOCK_OTP=true

# ============================================
# Resend (transactional email)
# ============================================
RESEND_API_KEY=
RESEND_FROM_ADDRESS="NexGen Connect <hello@nexgenconnect.com>"

# ============================================
# Server-side hashing peppers — generate with: openssl rand -hex 32
# ============================================
PHONE_PEPPER=
OTP_PEPPER=

# ============================================
# Plausible analytics
# ============================================
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=nexgenconnect.com
